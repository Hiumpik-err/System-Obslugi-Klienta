<Window x:Class="AdminSite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdminSite"
        mc:Ignorable="d"
        Title="CareFlow - Customer Service Dashboard" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen" Background="#FFF8FAFC">

    <Window.Resources>
        <!-- Styl dla przycisków w nowoczesnym designie -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Główny kontener przewijany -->
        <ScrollViewer x:Name="MainScrollViewer" ScrollChanged="MainScrollViewer_ScrollChanged">
            <StackPanel>

                <!-- 1. SEKCJA PARALAKSY & POWITANIA -->
                <Canvas x:Name="ParallaxCanvas" Height="500" Background="#FFF5F3FF" ClipToBounds="True">

                    <!-- Pływające "leki" (pigułki) - pozycjonowane absolutnie, animowane w Code-Behind -->
                    <!-- Kominkowy (koral) -->
                    <Border x:Name="PillCoral" Canvas.Left="100" Canvas.Top="100" Width="120" Height="45" CornerRadius="22.5" Background="#FFFF6F59">
                        <TextBlock Text="●  ○" Foreground="White" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Jasny Różowy -->
                    <Border x:Name="PillPink" Canvas.Left="750" Canvas.Top="180" Width="90" Height="36" CornerRadius="18" Background="#FFFFD3E8"/>

                    <!-- Biały -->
                    <Border x:Name="PillWhite" Canvas.Left="250" Canvas.Top="350" Width="140" Height="56" CornerRadius="28" Background="White" BorderBrush="#FFE2E8F0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#FFF1F5F9" CornerRadius="28,0,0,28"/>
                        </Grid>
                    </Border>

                    <!-- Jasny niebieski -->
                    <Border x:Name="PillBlue" Canvas.Left="550" Canvas.Top="80" Width="110" Height="44" CornerRadius="22" Background="#FFB3E5FC"/>

                    <!-- Fioletowy -->
                    <Border x:Name="PillPurple" Canvas.Left="800" Canvas.Top="380" Width="130" Height="52" CornerRadius="26" Background="#FFD1C4E9"/>

                    <!-- Treść Powitalna (Wjeżdżająca z lewej) -->
                    <StackPanel x:Name="WelcomePanel" Canvas.Left="-500" Canvas.Top="150" Width="600" Margin="50,0,0,0">
                        <Border Background="#FFE0E7FF" CornerRadius="12" HorizontalAlignment="Left" Padding="8,4" Margin="0,0,0,15">
                            <TextBlock Text="✨ Witaj Kamil! Twój system działa stabilnie." Foreground="#FF4F46E5" FontSize="12" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Witaj Kamil!" FontSize="48" FontWeight="Black" Foreground="#FF1E293B"/>
                        <TextBlock Text="Co dziś robimy?" FontSize="40" FontWeight="Bold" Foreground="#FF4F46E5" Margin="0,0,0,10"/>
                        <TextBlock Text="Monitoruj zgłoszenia klientów, planuj ich realizację na osi czasu oraz automatyzuj naprawy w locie." FontSize="14" Foreground="#FF64748B" TextWrapping="Wrap" Margin="0,0,0,20"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Otwórz planer kalendarza" Style="{StaticResource ModernButton}" Click="OpenPlanner_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Canvas>

                <!-- 2. SEKCJA: NOWO ODEBRANE UWAGI -->
                <StackPanel Margin="40,40,40,20">
                    <TextBlock Text="Najnowsze zgłoszenia" Foreground="#FF4F46E5" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="Nowo odebrane uwagi" FontSize="28" FontWeight="Bold" Foreground="#FF0F172A" Margin="0,5,0,20"/>

                    <ItemsControl x:Name="NewRemarksItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="10" Padding="20" Background="White" CornerRadius="16" BorderBrush="#FFE2E8F0" BorderThickness="1" MouseDown="Card_MouseDown" Cursor="Hand">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,10">
                                            <Border CornerRadius="10" Padding="8,3" Background="#FFFEE2E2">
                                                <TextBlock Text="{Binding Type}" Foreground="#FFEF4444" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Margin="0,0,0,15">
                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="#FF1E293B" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Desc}" FontSize="12" Foreground="#FF64748B" Margin="0,8,0,0" MaxHeight="60" TextTrimming="CharacterEllipsis" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Grid Grid.Row="2" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding User}" FontSize="11" Foreground="#FF475569" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding Date}" FontSize="11" Foreground="#FF94A3B8" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- 3. SEKCJA: WSZYSTKIE (REJESTR TABELARYCZNY) -->
                <StackPanel x:Name="AllSection" Margin="40,20,40,40">
                    <TextBlock Text="Pełna ewidencja systemowa" Foreground="#FF4F46E5" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="Wszystkie zgłoszenia" FontSize="28" FontWeight="Bold" Foreground="#FF0F172A" Margin="0,5,0,20"/>

                    <DataGrid x:Name="AllItemsGrid" AutoGenerateColumns="False" IsReadOnly="True" Background="White" RowHeaderWidth="0" GridLinesVisibility="None" BorderThickness="1" BorderBrush="#FFE2E8F0" MouseDoubleClick="AllItemsGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                            <DataGridTextColumn Header="Temat" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Kategoria" Binding="{Binding Category}" Width="150"/>
                            <DataGridTextColumn Header="Priorytet" Binding="{Binding Priority}" Width="120"/>
                            <DataGridTextColumn Header="Użytkownik" Binding="{Binding User}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- PŁYWAJĄCY TOAST (ZAPLANUJ WYKONANIE) -->
        <!-- Poprawione: Przeniesienie Padding="15" z Grid do Border nadrzędnego -->
        <Border x:Name="ToastNotification" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,30,30" Background="#FF1E1B4B" CornerRadius="16" Width="320" Height="150" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5" Padding="15">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="Masz wolne sloty!" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    <Button Content="X" Foreground="White" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Click="CloseToast_Click"/>
                </Grid>
                <TextBlock Grid.Row="1" Text="Zaplanuj wykonanie tych zgłoszeń w kalendarzu, aby zoptymalizować pracę." Foreground="#FFC7D2FE" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                    <Button Content="Anuluj" Background="Transparent" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="CloseToast_Click"/>
                    <Button Content="Zaplanuj" Style="{StaticResource ModernButton}" Padding="10,5" FontSize="11" Click="OpenPlanner_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>