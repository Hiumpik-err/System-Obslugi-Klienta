<Window x:Class="AdminSite.Views.PlannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdminSite.Views"
        mc:Ignorable="d"
        Title="CareFlow - Planer i Kalendarz" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#FFF8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek i przełączniki -->
        <Grid Margin="0,0,0,20">
            <StackPanel>
                <Button Content="← Powrót do pulpitu" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Foreground="#FF4F46E5" FontWeight="Bold" Click="Back_Click"/>
                <TextBlock Text="Kalendarz Planowania" FontSize="28" FontWeight="Bold" Foreground="#FF0F172A" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="◀ Poprzedni miesiąc" Margin="0,0,10,0" Padding="10,5" Click="PrevMonth_Click"/>
                <TextBlock x:Name="TxtMonthYear" Text="Czerwiec 2026" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
                <Button Content="Następny miesiąc ▶" Margin="10,0,0,0" Padding="10,5" Click="NextMonth_Click"/>
            </StackPanel>
        </Grid>

        <!-- Główna struktura planera (Lista zgłoszeń z lewej, Kalendarz z prawej) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lewy Panel: Lista do przeciągania -->
            <Border Background="White" CornerRadius="16" BorderBrush="#FFE2E8F0" BorderThickness="1" Padding="15" Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Zgłoszenia do zaplanowania" FontWeight="Bold" FontSize="14" Foreground="#FF1E293B" Margin="0,0,0,10"/>

                    <ListBox x:Name="UnplannedListBox" Grid.Row="1" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonDown="UnplannedListBox_PreviewMouseLeftButtonDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFF1F5F9" CornerRadius="8" Padding="10" Margin="0,0,0,8" Width="230">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Id}" FontSize="10" FontFamily="Consolas" Foreground="#FF4F46E5"/>
                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Prawy Panel: Kalendarz -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Dni tygodnia -->
                <UniformGrid Columns="7" Height="30">
                    <TextBlock Text="Pon" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Wt" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Śr" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Czw" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Pt" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Sob" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Nd" FontWeight="Bold" HorizontalAlignment="Center"/>
                </UniformGrid>

                <!-- Kafelki dni (Generowane dynamicznie w C#) -->
                <UniformGrid x:Name="CalendarGrid" Grid.Row="1" Columns="7" Rows="5"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
